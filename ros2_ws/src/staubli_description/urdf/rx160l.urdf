<?xml version="1.0" ?>
<robot name="staubli_rx160l">

  <!-- ═══════════════════════════════════════════════════════
       MATÉRIAUX
  ═══════════════════════════════════════════════════════════ -->
  <material name="staubli_yellow"><color rgba="1.0 0.6078 0.0 1.0"/></material>
  <material name="staubli_grey"><color rgba="0.53 0.52 0.51 1.0"/></material>

  <!-- ═══════════════════════════════════════════════════════
       WORLD (fixe)
  ═══════════════════════════════════════════════════════════ -->
  <link name="world"/>
  <joint name="world_to_base" type="fixed">
    <parent link="world"/><child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════
       BASE
  ═══════════════════════════════════════════════════════════ -->
  <link name="base_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><mesh filename="package://staubli_description/meshes/visual/base_link.stl"/></geometry>
      <material name="staubli_yellow"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><mesh filename="package://staubli_description/meshes/collision/base_link.stl"/></geometry>
    </collision>
    <inertial>
      <mass value="23.085357"/>
      <origin rpy="0.0 0.0 0.0" xyz="0.007579 0.000017 0.180670"/>
      <inertia ixx="0.343576" ixy="-0.000062" ixz="-0.002079"
               iyy="0.336217" iyz="-0.000014" izz="0.334050"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════
       JOINT 1 — axe Z (rotation base → épaule)
  ═══════════════════════════════════════════════════════════ -->
  <joint name="joint_1" type="revolute">
    <origin rpy="0 0 0" xyz="0 0 0.55"/>
    <parent link="base_link"/><child link="link_1"/>
    <axis xyz="0 0 1"/>
    <limit effort="692.0" lower="-2.7925" upper="2.7925" velocity="3.49"/>
  </joint>

  <link name="link_1">
    <visual>
      <geometry><mesh filename="package://staubli_description/meshes/visual/link_1.stl"/></geometry>
      <material name="staubli_yellow"/>
    </visual>
    <collision>
      <geometry><mesh filename="package://staubli_description/meshes/collision/link_1.stl"/></geometry>
    </collision>
    <inertial>
      <mass value="45.357763"/>
      <origin rpy="0.0 0.0 0.0" xyz="0.085479 -0.002547 -0.040488"/>
      <inertia ixx="0.839141" ixy="0.022637" ixz="0.162457"
               iyy="1.030146" iyz="0.027416" izz="1.064698"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════
       JOINT 2 — axe Y (bras supérieur)
  ═══════════════════════════════════════════════════════════ -->
  <joint name="joint_2" type="revolute">
    <origin rpy="0 0 0" xyz="0.15 0 0"/>
    <parent link="link_1"/><child link="link_2"/>
    <axis xyz="0 1 0"/>
    <limit effort="574.0" lower="-2.3998" upper="2.3998" velocity="3.49"/>
  </joint>

  <link name="link_2">
    <visual>
      <geometry><mesh filename="package://staubli_description/meshes/visual/link_2.stl"/></geometry>
      <material name="staubli_yellow"/>
    </visual>
    <collision>
      <geometry><mesh filename="package://staubli_description/meshes/collision/link_2.stl"/></geometry>
    </collision>
    <inertial>
      <mass value="51.266495"/>
      <origin rpy="0.0 0.0 0.0" xyz="-0.000002 0.264164 0.347704"/>
      <inertia ixx="5.272800" ixy="0.000010" ixz="0.000017"
               iyy="5.536809" iyz="-0.008261" izz="0.486191"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════
       JOINT 3 — axe Y (avant-bras)
  ═══════════════════════════════════════════════════════════ -->
  <joint name="joint_3" type="revolute">
    <origin rpy="0 0 0" xyz="0 0 0.825"/>
    <parent link="link_2"/><child link="link_3"/>
    <axis xyz="0 1 0"/>
    <limit effort="242.0" lower="-2.6179" upper="2.6179" velocity="4.45"/>
  </joint>

  <link name="link_3">
    <visual>
      <geometry><mesh filename="package://staubli_description/meshes/visual/link_3.stl"/></geometry>
      <material name="staubli_yellow"/>
    </visual>
    <collision>
      <geometry><mesh filename="package://staubli_description/meshes/collision/link_3.stl"/></geometry>
    </collision>
    <inertial>
      <mass value="19.754401"/>
      <origin rpy="0.0 0.0 0.0" xyz="-0.000255 0.016478 -0.003819"/>
      <inertia ixx="0.249388" ixy="-0.004901" ixz="0.004825"
               iyy="0.211780" iyz="0.000574" izz="0.238488"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════
       JOINT 4 — axe Z (poignet rotation)
  ═══════════════════════════════════════════════════════════ -->
  <joint name="joint_4" type="revolute">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="link_3"/><child link="link_4"/>
    <axis xyz="0 0 1"/>
    <limit effort="58.0" lower="-4.7123" upper="4.7123" velocity="5.49"/>
  </joint>

  <link name="link_4">
    <visual>
      <geometry><mesh filename="package://staubli_description/meshes/visual/link_4.stl"/></geometry>
      <material name="staubli_yellow"/>
    </visual>
    <collision>
      <geometry><mesh filename="package://staubli_description/meshes/collision/link_4.stl"/></geometry>
    </collision>
    <inertial>
      <mass value="15.287896"/>
      <origin rpy="0.0 0.0 0.0" xyz="-0.015515 0.000164 0.340348"/>
      <inertia ixx="0.331593" ixy="0.000055" ixz="-0.010688"
               iyy="0.320895" iyz="0.000058" izz="0.086557"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════
       JOINT 5 — axe Y (poignet flexion)
  ═══════════════════════════════════════════════════════════ -->
  <joint name="joint_5" type="revolute">
    <origin rpy="0 0 0" xyz="0 0 0.625"/>
    <parent link="link_4"/><child link="link_5"/>
    <axis xyz="0 1 0"/>
    <limit effort="29.0" lower="-1.8325" upper="2.0943" velocity="6.28"/>
  </joint>

  <link name="link_5">
    <visual>
      <geometry><mesh filename="package://staubli_description/meshes/visual/link_5.stl"/></geometry>
      <material name="staubli_grey"/>
    </visual>
    <collision>
      <geometry><mesh filename="package://staubli_description/meshes/collision/link_5.stl"/></geometry>
    </collision>
    <inertial>
      <mass value="0.548088"/>
      <origin rpy="0.0 0.0 0.0" xyz="0.000000 -0.000347 0.023671"/>
      <inertia ixx="0.000876" ixy="0.000000" ixz="0.000000"
               iyy="0.000889" iyz="0.000005" izz="0.000412"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════
       JOINT 6 — axe Z (flange)
  ═══════════════════════════════════════════════════════════ -->
  <joint name="joint_6" type="revolute">
    <origin rpy="0 0 0" xyz="0 0 0.11"/>
    <parent link="link_5"/><child link="link_6"/>
    <axis xyz="0 0 1"/>
    <limit effort="29.0" lower="-4.7123" upper="4.7123" velocity="15.18"/>
  </joint>

  <link name="link_6">
    <visual>
      <geometry><mesh filename="package://staubli_description/meshes/visual/link_6.stl"/></geometry>
      <material name="staubli_grey"/>
    </visual>
    <collision>
      <geometry><mesh filename="package://staubli_description/meshes/collision/link_6.stl"/></geometry>
    </collision>
    <inertial>
      <mass value="0.038484"/>
      <origin rpy="0.0 0.0 0.0" xyz="-0.000245 0.000000 -0.007626"/>
      <inertia ixx="0.000011" ixy="0.000000" ixz="0.000000"
               iyy="0.000011" iyz="0.000000" izz="0.000021"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════
       FLANGE TCP
  ═══════════════════════════════════════════════════════════ -->
  <joint name="joint_flange" type="fixed">
    <parent link="link_6"/><child link="flange"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>
  <link name="flange"/>

</robot>
