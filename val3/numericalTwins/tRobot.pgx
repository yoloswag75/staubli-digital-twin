<?xml version="1.0" encoding="utf-8"?>
<Programs xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://www.staubli.com/robotics/VAL3/Program/2">
  <Program name="tRobot">
    <Locals>
      <Local name="l_nIdx" type="num" xsi:type="array" size="1" />
    </Locals>
    <Code><![CDATA[begin
  resetMotion(jStart)

  while !bFinish
    // Attente qu il y ait au moins un point dans la file
    wait(nQueueCount > 0)

    // Lecture du point courant dans la file
    l_nIdx = nQueueRead

    // Verification continuite des trames
    if nIndexQueue[l_nIdx] == nLastIndex + 1

      // Configuration vitesse pour ce point
      setSpeed(mNomSpeed, nVelQueue[l_nIdx])

      // Execution du mouvement selon le type
      if nTypeQueue[l_nIdx] == 0
        movej(pCmdQueue[l_nIdx], flange, mNomSpeed)
      else
        movel(pCmdQueue[l_nIdx], flange, mNomSpeed)
      endIf

      nLastIndex = nIndexQueue[l_nIdx]

      // Envoi ACK + etat file : {ACK;index_execute;n_restant}
      sAck = "{ACK;" + toString("", nLastIndex) + ";" + toString("", nQueueCount) + "}"
      nAckIndex = 0
      while nAckIndex < len(sAck)
        sioSet(sioSocket, asc(sAck, nAckIndex))
        nAckIndex = nAckIndex + 1
      endWhile
      sioSet(sioSocket, nEol)

    else
      logMsg("Erreur trame, attendue: " + toString("", nLastIndex+1) + " recue: " + toString("", nIndexQueue[l_nIdx]))
      nLastIndex = nIndexQueue[l_nIdx] - 1
    endIf

    // Avance le pointeur de lecture
    nQueueRead  = (nQueueRead + 1) mod nQueueSize
    nQueueCount = nQueueCount - 1

    delay(0)
  endWhile

  waitEndMove()
end]]></Code>
  </Program>
</Programs>
