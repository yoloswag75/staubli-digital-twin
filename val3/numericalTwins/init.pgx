<?xml version="1.0" encoding="utf-8"?>
<Programs xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://www.staubli.com/robotics/VAL3/Program/2">
  <Program name="init">
    <Code><![CDATA[begin
  // Noms des taches
  sTaskPos   = "tPosition"
  sTaskCmd   = "tCommande"
  sTaskRobot = "tRobot"

  // Overrun
  bOvrPosition = false
  nOvrPos      = 0
  nPrevOvrPos  = 0

  // Index trames emises
  nFrameIndex = 0

  // Caracteres de protocole
  nEol     = 10
  nSof     = asc("{", 0)
  nEof     = asc("}", 0)
  nDivider = asc(";", 0)

  // File circulaire
  nQueueSize  = 5
  nQueueWrite = 0
  nQueueRead  = 0
  nQueueCount = 0

  // Flags
  bFinish    = false
  nLastIndex = -1

  // Socket TCP
  sioCtrl(sioSocket, "port",        2005)
  sioCtrl(sioSocket, "target",      "192.168.0.3")
  sioCtrl(sioSocket, "endOfString", nEol)
  sioCtrl(sioSocket, "timeout",     -1)
  sioCtrl(sioSocket, "nagle",       false)
end]]></Code>
  </Program>
</Programs>
