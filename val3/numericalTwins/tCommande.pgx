<?xml version="1.0" encoding="utf-8"?>
<Programs xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://www.staubli.com/robotics/VAL3/Program/2">
  <Program name="tCommande">
    <Code><![CDATA[begin
  // Trame attendue depuis le PC :
  // {index;type;x;y;z;rx;ry;rz}
  // type = 0 → movej  (aller au point en optimisant le trajet)
  // type = 1 → movel  (aller au point en ligne droite)
  // x, y, z  en mm | rx, ry, rz en degrés | repère world

  while true
    // Attente que tRobot ait consommé la commande précédente
    wait(bNewCmd == false)

    // Recherche du début de trame '{'
    do
      nNbChar = sioGet(sioSocket, nData)
    until nNbChar > 0 and nData == nSof

    // Lecture des 8 champs
    call getNum(nCmdIndex,        nDivider)  // index
    call getNum(nCmdType,         nDivider)  // type (0=movej, 1=movel)
    call getNum(pCmd.trsf.x,      nDivider)  // X (mm)
    call getNum(pCmd.trsf.y,      nDivider)  // Y (mm)
    call getNum(pCmd.trsf.z,      nDivider)  // Z (mm)
    call getNum(pCmd.trsf.rx,     nDivider)  // RX (degrés)
    call getNum(pCmd.trsf.ry,     nDivider)  // RY (degrés)
    call getNum(pCmd.trsf.rz,     nEof)      // RZ (degrés), terminé par '}'

    // Signal : nouvelle commande disponible pour tRobot
    bNewCmd = true

    delay(0)
  endWhile
end]]></Code>
  </Program>
</Programs>
